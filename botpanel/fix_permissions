#!/usr/bin/env bash
set -o pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
accounts_file="$script_dir/accounts.txt"
install_root="${CATHOOK_ROOT:-/opt/cathook}"
shared_steamapps="${CAT_SHARED_STEAMAPPS:-/opt/steamapps}"
interval="${CAT_FIX_PERMISSIONS_INTERVAL_SECONDS:-1}"
target_user_override="${CAT_FIX_PERMISSIONS_USER:-}"
fix_host_steam="${CAT_FIX_PERMISSIONS_HOST_STEAM:-1}"
quiet="${CAT_FIX_PERMISSIONS_QUIET:-0}"
run_once=0

usage() {
    cat <<'EOF'
Usage: ./botpanel/fix_permissions [--once] [--interval SECONDS] [-silent]

Continuously repairs ownership and permissions for botpanel runtime paths.
The first pass runs immediately; by default the script repeats every second.

Environment:
  CATHOOK_ROOT=/opt/cathook
  CAT_SHARED_STEAMAPPS=/opt/steamapps
  CAT_STEAM_ROOT=/path/to/steam
  CAT_STEAMAPPS_PATH=/path/to/steamapps
  TF2_PATH=/path/to/Team Fortress 2
  CAT_FIX_PERMISSIONS_INTERVAL_SECONDS=1
  CAT_FIX_PERMISSIONS_USER=username
  CAT_FIX_PERMISSIONS_HOST_STEAM=0   Skip host Steam/TF2 paths.
  CAT_FIX_PERMISSIONS_QUIET=1
EOF
}

log() {
    if [ "$quiet" = "1" ]; then
        return
    fi

    printf '[fix_permissions] %s\n' "$*"
}

is_enabled() {
    case "${1:-}" in
        "" | 0 | false | FALSE | no | NO | off | OFF)
            return 1
            ;;
    esac

    return 0
}

parse_args() {
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --once)
                run_once=1
                ;;
            --interval)
                if [ "$#" -lt 2 ]; then
                    echo "--interval requires a value." >&2
                    exit 1
                fi
                interval="$2"
                shift
                ;;
            --quiet)
                quiet=1
                ;;
            -silent | --silent)
                quiet=1
                ;;
            -h | --help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown fix_permissions option: $1" >&2
                usage >&2
                exit 1
                ;;
        esac
        shift
    done
}

run_as_root() {
    if [ "$(id -u)" -eq 0 ]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        echo "sudo is required for ownership and permission repair." >&2
        exit 1
    fi
}

user_name_from_uid() {
    local uid="$1"

    if command -v getent >/dev/null 2>&1; then
        getent passwd "$uid" | awk -F: '{ print $1; exit }'
        return
    fi

    id -un "$uid" 2>/dev/null || true
}

user_home_from_name() {
    local user_name="$1"

    if command -v getent >/dev/null 2>&1; then
        getent passwd "$user_name" | awk -F: '{ print $6; exit }'
        return
    fi

    printf '%s\n' "$HOME"
}

resolve_target_identity() {
    if [ -n "$target_user_override" ]; then
        target_uid="$(id -u "$target_user_override")"
        target_gid="$(id -g "$target_user_override")"
        target_user="$target_user_override"
    elif [ "$(id -u)" -eq 0 ] && [ -n "${SUDO_UID:-}" ] && [ -n "${SUDO_GID:-}" ]; then
        target_uid="$SUDO_UID"
        target_gid="$SUDO_GID"
        target_user="$(user_name_from_uid "$target_uid")"
    else
        target_uid="$(id -u)"
        target_gid="$(id -g)"
        target_user="$(id -un)"
    fi

    if [ -z "$target_user" ]; then
        target_user="$(id -un "$target_uid" 2>/dev/null || printf '%s\n' "$target_uid")"
    fi

    target_home="$(user_home_from_name "$target_user")"
}

resolved_path() {
    readlink -f "$1" 2>/dev/null || printf '%s\n' "$1"
}

safe_to_fix() {
    local path="$1"
    local resolved=""
    local home_resolved=""

    [ -n "$path" ] || return 1
    resolved="$(resolved_path "$path")"
    home_resolved="$(resolved_path "$target_home")"

    case "$resolved" in
        / | /home | /opt | /usr | /var | /tmp | /etc | /bin | /sbin | /lib | /lib64)
            return 1
            ;;
    esac

    [ "$resolved" != "$home_resolved" ]
}

fix_tree() {
    local path="$1"
    local label="$2"
    local resolved=""

    if [ ! -e "$path" ] && [ ! -L "$path" ]; then
        return
    fi

    if ! safe_to_fix "$path"; then
        log "skipping unsafe path: $path"
        return
    fi

    if [ -L "$path" ]; then
        run_as_root chown -h "$target_uid:$target_gid" "$path" 2>/dev/null || true
        resolved="$(resolved_path "$path")"
        if [ -n "$resolved" ] && [ "$resolved" != "$path" ] && [ -e "$resolved" ]; then
            fix_tree "$resolved" "$label symlink target"
        fi
        return
    fi

    log "fixing $label: $path"
    run_as_root chown -h "$target_uid:$target_gid" "$path" 2>/dev/null || true

    if [ -d "$path" ]; then
        run_as_root find "$path" -xdev \( ! -user "$target_uid" -o ! -group "$target_gid" \) -exec chown -h "$target_uid:$target_gid" {} + 2>/dev/null || true
        run_as_root find "$path" -xdev ! -type l -exec chmod u+rwX {} + 2>/dev/null || true
    else
        run_as_root chmod u+rw "$path" 2>/dev/null || true
    fi
}

ensure_accounts_file() {
    local temp_file=""

    if [ ! -e "$accounts_file" ] && [ ! -L "$accounts_file" ]; then
        temp_file="$(mktemp)"
        cat >"$temp_file" <<'EOF'
# Add one Steam account per line:
# username:password
EOF
        run_as_root install -m 0600 -o "$target_uid" -g "$target_gid" "$temp_file" "$accounts_file"
        rm -f "$temp_file"
        log "created $accounts_file"
        return
    fi

    run_as_root chown -h "$target_uid:$target_gid" "$accounts_file" 2>/dev/null || true
    if [ ! -L "$accounts_file" ]; then
        run_as_root chmod 0600 "$accounts_file" 2>/dev/null || true
    fi
}

fix_botpanel_executables() {
    local executable_path

    log "fixing botpanel executable bits"
    for executable_path in \
        "$script_dir/start" \
        "$script_dir/stop" \
        "$script_dir/update" \
        "$script_dir/fix-oldshi" \
        "$script_dir/fix_permissions" \
        "$script_dir/install-catbots" \
        "$script_dir/install-instances" \
        "$script_dir/remove-legacy" \
        "$script_dir/uninstall"; do
        [ -e "$executable_path" ] || continue
        run_as_root chown "$target_uid:$target_gid" "$executable_path" 2>/dev/null || true
        run_as_root chmod 0755 "$executable_path" 2>/dev/null || true
    done

    run_as_root find "$script_dir" -xdev -type f \( \
        -name "*.sh" -o \
        -name "start" -o \
        -name "start.legacy" -o \
        -name "stop" -o \
        -name "update" -o \
        -name "fix-oldshi" -o \
        -name "fix_permissions" -o \
        -name "install-catbots" -o \
        -name "install-instances" -o \
        -name "remove-legacy" -o \
        -name "uninstall" -o \
        -path "$script_dir/catbot-ipc-web-panel-main/scripts/ns-*" \
    \) -exec chmod 0755 {} + 2>/dev/null || true
}

fix_runtime_executables() {
    local runtime_dir

    log "fixing runtime executable bits"
    for runtime_dir in \
        "$install_root/bin" \
        "$install_root/ipc/bin" \
        "$repo_root/bin" \
        "$repo_root/opt/cathook/bin"; do
        [ -d "$runtime_dir" ] || continue
        run_as_root find "$runtime_dir" -maxdepth 1 -type f \( \
            -name "*.so" -o \
            -name "*.so.*" -o \
            -perm /111 \
        \) -exec chmod 0755 {} + 2>/dev/null || true
    done
}

fix_shared_libraries_in() {
    local root_path="$1"

    [ -d "$root_path" ] || return
    log "fixing shared libraries under $root_path"
    run_as_root find "$root_path" -xdev -type f \( \
        -name "*.so" -o \
        -name "*.so.*" -o \
        -name "libSDL*.so*" -o \
        -name "steam_api*.so*" -o \
        -name "libsteam_api*.so*" -o \
        -name "steamclient.so" -o \
        -name "libsteam*.so*" -o \
        -name "gameoverlayrenderer.so" -o \
        -name "libtier0.so" -o \
        -name "libvstdlib.so" \
    \) -exec chown "$target_uid:$target_gid" {} + -exec chmod 0755 {} + 2>/dev/null || true
}

fix_steam_executables_in() {
    local steam_root="$1"

    [ -d "$steam_root" ] || return
    log "fixing Steam executables under $steam_root"
    run_as_root find "$steam_root" -maxdepth 3 -type f \( \
        -name "steam" -o \
        -name "steam.sh" -o \
        -name "steamwebhelper" -o \
        -name "steamclient.so" -o \
        -name "*.so" -o \
        -name "*.so.*" \
    \) -exec chmod u+rx {} + 2>/dev/null || true
    fix_shared_libraries_in "$steam_root"
}

fix_tf2_executables_in() {
    local tf2_root="$1"

    [ -d "$tf2_root" ] || return
    log "fixing TF2 executables and libraries under $tf2_root"
    run_as_root find "$tf2_root" -maxdepth 3 -type f \( \
        -name "tf_linux64" -o \
        -name "*.so" -o \
        -name "*.so.*" \
    \) -exec chmod u+rx {} + 2>/dev/null || true
    fix_shared_libraries_in "$tf2_root"
}

fix_tmp_preload_libraries() {
    local preload_file

    log "fixing temporary preload libraries"
    shopt -s nullglob
    for preload_file in /tmp/.gl*; do
        [ -f "$preload_file" ] || continue
        run_as_root chown "$target_uid:$target_gid" "$preload_file" 2>/dev/null || true
        run_as_root chmod 0755 "$preload_file" 2>/dev/null || true
    done
    shopt -u nullglob
}

add_existing_path() {
    local path="$1"
    local label="$2"

    [ -n "$path" ] || return
    if [ ! -e "$path" ] && [ ! -L "$path" ]; then
        return
    fi

    target_paths+=("$path")
    target_labels+=("$label")
}

collect_paths() {
    local user_home="$target_home"
    local steam_root
    local steamapps_path
    local tf2_path

    target_paths=()
    target_labels=()
    steam_roots=()
    tf2_roots=()

    add_existing_path "$script_dir" "botpanel"
    add_existing_path "$install_root" "cathook runtime"
    add_existing_path "$repo_root/bin" "repo binaries"
    add_existing_path "$repo_root/opt/cathook" "bundled runtime"

    if ! is_enabled "$fix_host_steam"; then
        return
    fi

    for steam_root in \
        "${CAT_STEAM_ROOT:-}" \
        "$user_home/.steam/steam" \
        "$user_home/.local/share/Steam" \
        "$user_home/.steam/debian-installation"; do
        add_existing_path "$steam_root" "Steam root"
        [ -d "$steam_root" ] && steam_roots+=("$steam_root")
    done

    for steamapps_path in \
        "${CAT_STEAMAPPS_PATH:-}" \
        "${CAT_STEAM_ROOT:+$CAT_STEAM_ROOT/steamapps}" \
        "$shared_steamapps" \
        "$user_home/.steam/steam/steamapps" \
        "$user_home/.local/share/Steam/steamapps" \
        "$user_home/.steam/debian-installation/steamapps"; do
        add_existing_path "$steamapps_path" "Steam steamapps"
        if [ -d "$steamapps_path/common/Team Fortress 2" ]; then
            tf2_roots+=("$steamapps_path/common/Team Fortress 2")
        fi
    done

    for tf2_path in "${TF2_PATH:-}" "${tf2_roots[@]}"; do
        add_existing_path "$tf2_path" "Team Fortress 2"
    done
}

fix_collected_paths() {
    local index

    for index in "${!target_paths[@]}"; do
        fix_tree "${target_paths[$index]}" "${target_labels[$index]}"
    done
}

fix_collected_executables() {
    local steam_root
    local tf2_root

    fix_botpanel_executables
    fix_runtime_executables
    fix_tmp_preload_libraries
    fix_shared_libraries_in "$install_root"
    fix_shared_libraries_in "$repo_root/bin"
    fix_shared_libraries_in "$repo_root/opt/cathook"

    for steam_root in "${steam_roots[@]}"; do
        fix_steam_executables_in "$steam_root"
    done

    for tf2_root in "${tf2_roots[@]}" "${TF2_PATH:-}"; do
        fix_tf2_executables_in "$tf2_root"
    done
}

repair_once() {
    log "starting repair pass"
    fix_botpanel_executables
    collect_paths
    fix_collected_paths
    ensure_accounts_file
    fix_collected_executables
    ensure_accounts_file
    log "repair pass done"
}

parse_args "$@"

if [ "$(uname -s)" != "Linux" ]; then
    echo "./botpanel/fix_permissions must run on Linux." >&2
    exit 1
fi

case "$interval" in
    "" | *[!0-9]*)
        echo "Interval must be a positive integer number of seconds." >&2
        exit 1
        ;;
    0)
        echo "Interval must be greater than zero." >&2
        exit 1
        ;;
esac

resolve_target_identity
log "target owner: $target_user ($target_uid:$target_gid), interval=${interval}s"

while :; do
    if ! repair_once; then
        log "repair pass failed; retrying in ${interval}s"
    fi
    if [ "$run_once" = "1" ]; then
        exit 0
    fi
    sleep "$interval"
done
