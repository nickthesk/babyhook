start_panel_permission_loop() {
    local web_panel_scripts_dir="$web_panel_root/scripts"
    local fix_interval="${CAT_PERMISSION_FIX_INTERVAL_SECONDS:-30}"
    local target_uid target_gid
    target_uid="$(id -u)"
    target_gid="$(id -g)"

    chmod 0755 "$web_panel_scripts_dir/ns-inet" "$web_panel_scripts_dir/ns-delete" 2>/dev/null || true

    (
        while :; do
            sleep "$fix_interval"
            run_as_root chmod 0755 "$web_panel_scripts_dir/ns-inet" "$web_panel_scripts_dir/ns-delete" 2>/dev/null || true
            run_as_root chown -h "$target_uid:$target_gid" "$web_panel_scripts_dir/ns-inet" "$web_panel_scripts_dir/ns-delete" 2>/dev/null || true
        done
    ) </dev/null >/dev/null 2>&1 &
    disown 2>/dev/null || true
}

