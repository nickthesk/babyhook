        return
    fi

    ensure_node_dependencies

    if [ ! -x "$web_panel_root/node_modules/.bin/browserify" ]; then
        echo "browserify is missing after npm install." >&2
        exit 1
    fi

    echo "Building web panel bundle..."
    mkdir -p "$web_panel_root/public"
    ( cd "$web_panel_root" && ./node_modules/.bin/browserify script.js -o public/bundle.js )
