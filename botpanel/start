#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
setup_root="$script_dir"
repo_root="$(cd -- "$script_dir/.." && pwd)"
ipc_server_root="$setup_root/catbot-ipc-server-main"
web_panel_root="$setup_root/catbot-ipc-web-panel-main"
accounts_file="$setup_root/accounts.txt"
user_instances_dir="$setup_root/user_instances"
install_root="${CATHOOK_ROOT:-/opt/cathook}"
requested_visible_windows="${CAT_VISIBLE_WINDOWS:-0}"
requested_display_backend="${CAT_DISPLAY_BACKEND:-}"
requested_chunked_x_display="${CAT_CHUNKED_X_DISPLAY:-1}"
default_headless_display="${CAT_DEFAULT_DISPLAY:-:699}"
for system_path_entry in /usr/local/sbin /usr/sbin /sbin; do
    case ":$PATH:" in
        *":$system_path_entry:"*) ;;
        *) PATH="$PATH:$system_path_entry" ;;
    esac
done
export PATH

if [ "$requested_visible_windows" = "1" ]; then
    visible_windows=1
    display="${CAT_DISPLAY:-${DISPLAY:-:0}}"
    use_xpra=0
    use_xvfb=0
else
    visible_windows=0
    display="${CAT_XPRA_DISPLAY:-${CAT_DISPLAY:-${CAT_XVFB_DISPLAY:-$default_headless_display}}}"
    use_xpra=1
    use_xvfb=0
fi
port="${CAT_IPC_PORT:-7655}"
textmode_game="${CAT_TEXTMODE_GAME:-1}"
launcher_version="legacy_style_runtime_bundle_xpra"
xpra_log="${CAT_XPRA_LOG:-/tmp/cat-catbot-xpra.log}"
xvfb_log="${CAT_XVFB_LOG:-/tmp/cat-catbot-xvfb.log}"
xvfb_pid_file="${CAT_XVFB_PID_FILE:-/tmp/cat-catbot-xvfb.pid}"
xvfb_max_clients="${CAT_XVFB_MAX_CLIENTS:-512}"
xpra_screen_size="${CAT_XPRA_SCREEN:-${CAT_X_SCREEN:-1x1x24}}"
xvfb_screen_size="${CAT_XVFB_SCREEN:-${CAT_X_SCREEN:-1x1x24}}"

run_as_root() {
    if [ "$(id -u)" -eq 0 ]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        echo "sudo is required for installing runtime files and running the panel." >&2
        exit 1
    fi
}

run_workspace_permission_find() {
    run_as_root find "$repo_root" \( \
        -path "$repo_root/externalprojects" -o \
        -path "$repo_root/opt" -o \
        -path "$repo_root/botpanel/cathook-location" -o \
        -path "$repo_root/botpanel/catbot-ipc-server" -o \
        -path "$repo_root/botpanel/catbot-ipc-web-panel" -o \
        -path "$repo_root/botpanel/account-generator" -o \
        -path "$repo_root/botpanel/catbot-database" -o \
        -path "$repo_root/botpanel/catbot" -o \
        -path "$repo_root/botpanel/just-disable-vac" -o \
        -path "$repo_root/botpanel/kisak" -o \
        -path "$repo_root/botpanel/users" -o \
        -path "$repo_root/botpanel/steams" -o \
        -path "$repo_root/botpanel/user_instances" -o \
        -path "$repo_root/botpanel/build" -o \
        -path "$repo_root/botpanel/build-debug" -o \
        -name "node_modules" \
    \) -prune -o "$@"
}

fix_workspace_permissions() {
    local target_uid
    local target_gid

    target_uid="$(id -u)"
    target_gid="$(id -g)"

    echo "Fixing workspace permissions under $repo_root..."
    run_workspace_permission_find -exec chown -h "$target_uid:$target_gid" {} +
    run_workspace_permission_find ! -type l -exec chmod u+rwX,go+rX {} +

    run_workspace_permission_find -type f \( \
        -name "*.sh" -o \
        -name "build.sh" -o \
        -name "debug.sh" -o \
        -name "inject.sh" -o \
        -name "install-deps" -o \
        -name "setup.sh" -o \
        -name "start" -o \
        -name "start.legacy" -o \
        -name "stop" -o \
        -name "update" -o \
        -name "fix-oldshi" -o \
        -name "fix_permissions" -o \
        -name "install-catbots" -o \
        -name "remove-legacy" -o \
        -name "uninstall" -o \
        -path "*/scripts/ns-*" \
    \) -exec chmod 0755 {} +
}

need_command() {
    ! command -v "$1" >/dev/null 2>&1
}

node_command() {
    if command -v node >/dev/null 2>&1; then
        printf '%s\n' node
        return 0
    fi
    if command -v nodejs >/dev/null 2>&1; then
        printf '%s\n' nodejs
        return 0
    fi
    return 1
}

npm_command() {
    command -v npm >/dev/null 2>&1
}

apt_package_available() {
    apt-cache policy "$1" 2>/dev/null | awk '
        $1 == "Candidate:" {
            found = 1
            exit ($2 == "(none)" ? 1 : 0)
        }
        END {
            if (!found) {
                exit 1
            }
        }'
}

source_os_release() {
    if [ -r /etc/os-release ]; then
        # shellcheck disable=SC1091
        . /etc/os-release
    fi
}

xpra_repo_file() {
    case "${CAT_XPRA_REPO_CHANNEL:-stable}" in
        stable)
            printf '%s\n' "xpra.sources"
            ;;
        lts)
            printf '%s\n' "xpra-lts.sources"
            ;;
        beta)
            printf '%s\n' "xpra-beta.sources"
            ;;
        *)
            echo "Unsupported CAT_XPRA_REPO_CHANNEL=${CAT_XPRA_REPO_CHANNEL}. Use stable, lts, or beta." >&2
            return 1
            ;;
    esac
}

configure_xpra_repo() {
    local architecture=""
    local codename="${VERSION_CODENAME:-${UBUNTU_CODENAME:-}}"
    local repo_file=""
    local repo_url=""

    if [ "${CAT_INSTALL_XPRA_REPO:-1}" = "0" ]; then
        return 1
    fi

    if command -v dpkg >/dev/null 2>&1; then
        architecture="$(dpkg --print-architecture)"
    fi

    case "$architecture" in
        amd64 | arm64)
            ;;
        *)
            echo "Skipping Xpra upstream apt repo for unsupported architecture: ${architecture:-unknown}." >&2
            return 1
            ;;
    esac

    if [ -z "$codename" ]; then
        echo "Skipping Xpra upstream apt repo because the distro codename is unknown." >&2
        return 1
    fi

    if ! repo_file="$(xpra_repo_file)"; then
        return 1
    fi

    repo_url="https://raw.githubusercontent.com/Xpra-org/xpra/master/packaging/repos/$codename/$repo_file"

    echo "xpra package is not available in this apt repository; adding Xpra upstream apt repo for $codename."
    run_as_root apt-get install -y --no-install-recommends ca-certificates wget
    run_as_root install -d /usr/share/keyrings /etc/apt/sources.list.d

    if ! run_as_root wget -O /usr/share/keyrings/xpra.asc https://xpra.org/xpra.asc; then
        echo "Failed to download Xpra apt signing key." >&2
        return 1
    fi

    if ! run_as_root wget -O "/etc/apt/sources.list.d/$repo_file" "$repo_url"; then
        echo "Failed to download Xpra apt source file: $repo_url" >&2
        run_as_root rm -f "/etc/apt/sources.list.d/$repo_file"
        return 1
    fi

    run_as_root apt-get update
    apt_package_available xpra
}

make_shell_path() {
    if [ -x /bin/sh ]; then
        printf '%s\n' /bin/sh
        return
    fi

    if command -v bash >/dev/null 2>&1; then
        command -v bash
        return
    fi

    echo "No usable shell found for make. Install dash or bash, then run ./start again." >&2
    exit 1
}

run_make() {
    make SHELL="$(make_shell_path)" "$@"
}

install_dependency_packages() {
    if [ -x "$repo_root/packages/packages.sh" ]; then
        echo "Running distro dependency installer..."
        bash "$repo_root/packages/packages.sh"
        return
    fi

    if command -v apt-get >/dev/null 2>&1; then
        local apt_packages=(
            dbus
            dbus-x11
            firejail
            g++-multilib
            iptables
            iproute2
            libc6-dev-i386
            libopenal1
            nodejs
            npm
            xauth
            xserver-xorg-core
            xserver-xorg-video-dummy
            xvfb
        )

        run_as_root apt-get update

        if apt_package_available xpra || configure_xpra_repo; then
            apt_packages+=(xpra)
            if apt_package_available xpra-x11; then
                apt_packages+=(xpra-x11)
            fi
        else
            echo "xpra package is not available; using Xvfb for headless display."
        fi

        run_as_root apt-get install -y --no-install-recommends "${apt_packages[@]}"
        return
    fi

    if command -v pacman >/dev/null 2>&1; then
        run_as_root pacman -Sy --needed --noconfirm \
            firejail iproute2 iptables nodejs npm openal xorg-server-xvfb xorg-xauth xpra
        return
    fi

    if command -v dnf >/dev/null 2>&1; then
        run_as_root dnf -y install \
            firejail iproute iptables nodejs npm openal-soft xorg-x11-drv-dummy xorg-x11-server-Xvfb xorg-x11-xauth xpra
        return
    fi

    if command -v yum >/dev/null 2>&1; then
        run_as_root yum -y install \
            firejail iproute iptables nodejs npm openal-soft xorg-x11-drv-dummy xorg-x11-server-Xvfb xorg-x11-xauth xpra
        return
    fi

    if command -v zypper >/dev/null 2>&1; then
        run_as_root zypper --non-interactive install --no-recommends \
            firejail iproute2 iptables nodejs npm openal-soft xauth xorg-x11-server xorg-x11-server-extra xpra
        return
    fi

    if command -v apk >/dev/null 2>&1; then
        run_as_root apk add --no-cache \
            firejail iproute2 iptables nodejs npm openal-soft xauth xvfb xpra
        return
    fi

    if command -v xbps-install >/dev/null 2>&1; then
        run_as_root xbps-install -Sy \
            firejail iproute2 iptables nodejs libopenal xorg-server-xvfb xpra
        return
    fi

    return 1
}

collect_missing_runtime_dependencies() {
    local missing=()

    if need_command firejail; then
        missing+=("firejail")
    fi

    if need_command dbus-run-session && need_command dbus-launch; then
        missing+=("dbus or dbus-x11")
    fi

    if [ "$visible_windows" != "1" ] && need_command xpra && need_command Xvfb; then
        missing+=("xpra or Xvfb")
    fi

    if ! node_command >/dev/null 2>&1; then
        missing+=("nodejs")
    fi

    if ! npm_command; then
        missing+=("npm")
    fi

    if need_command ip; then
        missing+=("iproute2")
    fi

    if need_command iptables; then
        missing+=("iptables")
    fi

    if [ "${#missing[@]}" -ne 0 ]; then
        printf '%s\n' "${missing[@]}"
    fi
}

select_display_backend() {
    local has_xpra=0
    local has_xvfb=0
    local selected_backend=""

    if [ "$visible_windows" = "1" ]; then
        use_xpra=0
        use_xvfb=0
        launcher_version="legacy_style_runtime_bundle_visible"
        return
    fi

    if command -v xpra >/dev/null 2>&1; then
        has_xpra=1
    fi

    if command -v Xvfb >/dev/null 2>&1; then
        has_xvfb=1
    fi

    if [ "$has_xpra" != "1" ] && [ "$has_xvfb" != "1" ]; then
        echo "Headless mode requires xpra or Xvfb. Run ./install-deps, then try again." >&2
        exit 1
    fi

    if [ -n "$requested_display_backend" ]; then
        selected_backend="$requested_display_backend"
    elif [ "$requested_chunked_x_display" != "0" ] && [ "$has_xvfb" = "1" ]; then
        selected_backend="xvfb"
    elif [ "$has_xpra" = "1" ] && [ "$has_xvfb" = "1" ]; then
        selected_backend="$(prompt_display_backend)"
    elif [ "$has_xpra" = "1" ]; then
        selected_backend="xpra"
    else
        selected_backend="xvfb"
    fi

    case "$selected_backend" in
        xpra|XPRA)
            if [ "$has_xpra" != "1" ]; then
                echo "CAT_DISPLAY_BACKEND=xpra was requested, but xpra is not installed." >&2
                exit 1
            fi
            use_xpra=1
            use_xvfb=0
            launcher_version="legacy_style_runtime_bundle_xpra"
            stop_xvfb_display
            return
            ;;
        xvfb|Xvfb|XVFB)
            if [ "$has_xvfb" != "1" ]; then
                echo "CAT_DISPLAY_BACKEND=xvfb was requested, but Xvfb is not installed." >&2
                exit 1
            fi
            use_xpra=0
            use_xvfb=1
            launcher_version="legacy_style_runtime_bundle_xvfb"
            stop_xpra_display
            return
            ;;
        *)
            echo "Unsupported display backend '$selected_backend'. Use xpra or xvfb." >&2
            exit 1
            ;;
    esac
}

prompt_display_backend() {
    local choice

    if [ ! -t 0 ]; then
        echo "Both xpra and Xvfb are installed, but stdin is not interactive." >&2
        echo "Set CAT_DISPLAY_BACKEND=xpra or CAT_DISPLAY_BACKEND=xvfb, then run ./botpanel/start again." >&2
        exit 1
    fi

    while true; do
        echo "Choose headless display backend for this start:" >&2
        echo "  1) xpra with MaxClients 2048" >&2
        echo "  2) Xvfb with max clients $xvfb_max_clients" >&2
        printf "Selection [1/2]: " >&2
        read -r choice

        case "$choice" in
            1|xpra|XPRA)
                printf '%s\n' "xpra"
                return
                ;;
            2|xvfb|Xvfb|XVFB)
                printf '%s\n' "xvfb"
                return
                ;;
            *)
                echo "Please choose 1 for xpra or 2 for Xvfb." >&2
                ;;
        esac
    done
}

stop_xpra_display() {
    if command -v xpra >/dev/null 2>&1 && xpra_display_running; then
        echo "Stopping xpra display $display before starting Xvfb..."
        xpra stop "$display" >/tmp/cat-catbot-xpra-stop.log 2>&1 || true
    fi
}

stop_xvfb_display() {
    local display_number="${display#:}"
    local lock_path="/tmp/.X${display_number}-lock"
    local lock_pid=""
    local xvfb_pid=""

    if [ -f "$xvfb_pid_file" ]; then
        xvfb_pid="$(tr -d '[:space:]' <"$xvfb_pid_file" 2>/dev/null || true)"
        if is_pid_running "$xvfb_pid"; then
            echo "Stopping Xvfb display $display before starting xpra..."
            kill "$xvfb_pid" 2>/dev/null || true
        fi
        rm -f "$xvfb_pid_file"
    fi

    if [ -f "$lock_path" ]; then
        lock_pid="$(tr -d '[:space:]' <"$lock_path" 2>/dev/null || true)"
        if is_pid_running "$lock_pid" && ps -p "$lock_pid" -o args= 2>/dev/null | grep -Eq "(^|[[:space:]])Xvfb[[:space:]]+$display([[:space:]]|$)"; then
            echo "Stopping Xvfb display $display pid $lock_pid before starting xpra..."
            kill "$lock_pid" 2>/dev/null || true
        fi
    fi

    sleep 1
}

ensure_utmp_file() {
    if [ "$use_xpra" != "1" ]; then
        return
    fi

    if [ -e /var/run/utmp ] || [ -e /run/utmp ]; then
        return
    fi

    run_as_root touch /run/utmp
    run_as_root chmod 0664 /run/utmp
}

have_prebuilt_runtime() {
    local source_root="$1"

    [ -f "$source_root/bin/libcathook.so" ] &&
        [ -f "$source_root/bin/libcathooktextmode.so" ] &&
        [ -x "$ipc_server_root/bin/server" ] &&
        [ -x "$ipc_server_root/bin/console" ] &&
        [ -x "$ipc_server_root/bin/exec" ] &&
        [ -x "$ipc_server_root/bin/exec_all" ] &&
        [ -x "$ipc_server_root/bin/undeadlock" ]
}

runtime_source_root() {
    if [ -f "$repo_root/bin/libcathook.so" ] &&
       [ -f "$repo_root/bin/libcathooktextmode.so" ] &&
       [ -x "$ipc_server_root/bin/server" ]; then
        printf '%s\n' "$repo_root"
        return 0
    fi

    if have_prebuilt_runtime "$repo_root/opt/cathook"; then
        printf '%s\n' "$repo_root/opt/cathook"
        return 0
    fi

    return 1
}

install_missing_dependencies() {
    local missing=()
    mapfile -t missing < <(collect_missing_runtime_dependencies)

    if [ "${#missing[@]}" -eq 0 ]; then
        return
    fi

    echo "Missing runtime dependencies: ${missing[*]}"
    if ! install_dependency_packages; then
        echo "Install the missing dependencies on the VM, then run ./start again." >&2
        exit 1
    fi

    mapfile -t missing < <(collect_missing_runtime_dependencies)
    if [ "${#missing[@]}" -ne 0 ]; then
        echo "Still missing runtime dependencies after install attempt: ${missing[*]}" >&2
        exit 1
    fi
}

ensure_binaries() {
    if [ ! -f "$repo_root/Makefile" ]; then
        if runtime_source_root >/dev/null 2>&1; then
            echo "No Makefile at $repo_root; using bundled prebuilt runtime."
            return
        fi
        echo "Missing prebuilt Cat binaries and no source Makefile was found at $repo_root." >&2
        echo "Copy vm_dist/opt/cathook next to vm_dist/botpanel, or copy it to /opt/cathook." >&2
        exit 1
    fi

    if need_command make || need_command g++; then
        echo "Missing build tools; running distro dependency installer..."
        install_dependency_packages || {
            echo "Install make and g++, then run ./start again." >&2
            exit 1
        }
    fi

    echo "Rebuilding cathook from source under $repo_root (incremental)..."
    run_make -C "$repo_root"
    run_make -C "$repo_root" TEXTMODE=1
    run_make -C "$repo_root" catbot_ipc

    if [ ! -f "$repo_root/bin/libcathook.so" ] ||
       [ ! -f "$repo_root/bin/libcathooktextmode.so" ] ||
       [ ! -x "$ipc_server_root/bin/server" ]; then
        if runtime_source_root >/dev/null 2>&1; then
            echo "Warning: build did not produce all artifacts; falling back to existing runtime." >&2
            return
        fi
        echo "Build did not produce required artifacts under $repo_root/bin." >&2
        exit 1
    fi
}

find_shared_library() {
    local library_name="$1"
    local candidate=""

    if command -v ldconfig >/dev/null 2>&1; then
        candidate="$(ldconfig -p 2>/dev/null | awk -v library_name="$library_name" '$1 == library_name { print $NF; exit }')"
        if [ -n "$candidate" ] && [ -f "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    fi

    for candidate in \
        "/usr/lib/$library_name" \
        "/usr/lib64/$library_name" \
        "/usr/lib/x86_64-linux-gnu/$library_name" \
        "/usr/local/lib/$library_name" \
        "/run/host/usr/lib/$library_name" \
        "/run/host/usr/lib64/$library_name"; do
        if [ -f "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

install_bundled_glew_libraries() {
    local source_root="$1"
    local dependency_path=""

    for dependency_path in "$source_root/bin"/libGLEW.so.*; do
        [ -f "$dependency_path" ] || continue
        run_as_root install -m 0755 "$dependency_path" "$install_root/bin/$(basename -- "$dependency_path")"
    done
}

install_glew_dependency_for_binary() {
    local binary_path="$1"
    local required_library=""
    local source_path=""

    if [ ! -f "$binary_path" ]; then
        return
    fi

    if ! command -v readelf >/dev/null 2>&1; then
        echo "Warning: readelf is missing; cannot bundle libGLEW fallback for $binary_path." >&2
        return
    fi

    required_library="$(readelf -d "$binary_path" 2>/dev/null | awk -F'[][]' '/NEEDED/ && $2 ~ /^libGLEW\.so\./ { print $2; exit }')"
    if [ -z "$required_library" ] || [ -f "$install_root/bin/$required_library" ]; then
        return
    fi

    if ! source_path="$(find_shared_library "$required_library")"; then
        echo "Warning: $binary_path needs $required_library, but it was not found on this system." >&2
        echo "Provide $required_library in $install_root/bin or rebuild Cat on this machine." >&2
        return
    fi

    run_as_root install -m 0755 "$source_path" "$install_root/bin/$required_library"
}

install_runtime_dependencies() {
    local source_root="$1"

    install_bundled_glew_libraries "$source_root"
    install_glew_dependency_for_binary "$source_root/bin/libcathook.so"
    install_glew_dependency_for_binary "$source_root/bin/libcathooktextmode.so"
    install_glew_dependency_for_binary "$source_root/bin/libcathook-textmode.so"
}

install_runtime_configs() {
    local source_configs="$repo_root/opt/cathook/configs"
    local target_configs="$install_root/configs"
    local target_logs="$install_root/logs"
    local target_uid
    local target_gid
    local file
    local target_file

    target_uid="$(id -u)"
    target_gid="$(id -g)"

    run_as_root install -d -m 0755 "$target_configs" "$target_logs"

    if [ -d "$source_configs" ]; then
        while IFS= read -r -d '' file; do
            target_file="$target_configs/$(basename -- "$file")"
            if [ ! -e "$target_file" ]; then
                run_as_root install -m 0644 "$file" "$target_file"
            fi
        done < <(find "$source_configs" -maxdepth 1 -type f -name '*.cat' -print0)
    fi

    run_as_root chown -R "$target_uid:$target_gid" "$target_configs" "$target_logs" 2>/dev/null || true
}

install_runtime() {
    local source_root
    source_root="$(runtime_source_root)"

    run_as_root install -d "$install_root/bin" "$install_root/ipc/bin"
    if [ -f "$source_root/bin/libcathooktextmode.so" ]; then
        run_as_root install -m 0755 "$source_root/bin/libcathook.so" "$install_root/bin/libcathook.so"
        run_as_root install -m 0755 "$source_root/bin/libcathooktextmode.so" "$install_root/bin/libcathooktextmode.so"
        run_as_root install -m 0755 "$source_root/bin/libcathooktextmode.so" "$install_root/bin/libcathook-textmode.so"
    else
        run_as_root install -m 0755 "$source_root/bin/libcathook.so" "$install_root/bin/libcathook.so"
        run_as_root install -m 0755 "$source_root/bin/libcathook-textmode.so" "$install_root/bin/libcathooktextmode.so"
        run_as_root install -m 0755 "$source_root/bin/libcathook-textmode.so" "$install_root/bin/libcathook-textmode.so"
    fi

    install_runtime_dependencies "$source_root"
    install_runtime_configs
    run_as_root install -m 0755 "$ipc_server_root/bin/server" "$install_root/ipc/bin/server"
    run_as_root install -m 0755 "$ipc_server_root/bin/console" "$install_root/ipc/bin/console"
    run_as_root install -m 0755 "$ipc_server_root/bin/exec" "$install_root/ipc/bin/exec"
    run_as_root install -m 0755 "$ipc_server_root/bin/exec_all" "$install_root/ipc/bin/exec_all"
    run_as_root install -m 0755 "$ipc_server_root/bin/undeadlock" "$install_root/ipc/bin/undeadlock"
}

ensure_node_dependencies() {
    if [ -d "$web_panel_root/node_modules" ] && [ -x "$web_panel_root/node_modules/.bin/browserify" ]; then
        return
    fi

    if ! npm_command; then
        echo "npm is required to install $web_panel_root/node_modules." >&2
        install_dependency_packages || {
            echo "Install npm, then run ./start again." >&2
            exit 1
        }
    fi

    echo "Installing web panel npm dependencies..."
    ( cd "$web_panel_root" && npm install )
}

ensure_web_bundle() {
