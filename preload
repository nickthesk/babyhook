#!/usr/bin/env bash
set -euo pipefail

if [ "$EUID" -eq 0 ]; then
    echo "This script must not be run as root"
    exit 1
fi

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
CATHOOK_ROOT=${CATHOOK_ROOT:-/opt/cathook}
CATHOOK_BIN_DIR=$CATHOOK_ROOT/bin
CATHOOK_BINARY=${CATHOOK_BINARY:-libcathook.so}
TMP_RUNTIME_DIR=""

cleanup_temp_runtime() {
    if [ -n "$TMP_RUNTIME_DIR" ] && [ -d "$TMP_RUNTIME_DIR" ]; then
        rm -rf "$TMP_RUNTIME_DIR"
    fi
    TMP_RUNTIME_DIR=""
}

copy_bundled_runtime_dependencies() {
    local source_dir="$1"
    local target_dir="$2"
    local dependency_path=""
    local target_path=""

    if [ ! -d "$source_dir" ]; then
        return
    fi

    for dependency_path in "$source_dir"/libGLEW.so.*; do
        [ -f "$dependency_path" ] || continue
        target_path="$target_dir/$(basename -- "$dependency_path")"
        if [ "$dependency_path" = "$target_path" ]; then
            continue
        fi

        cp "$dependency_path" "$target_path"
        chmod 0755 "$target_path"
    done
}

find_shared_library() {
    local library_name="$1"
    local candidate=""

    if command -v ldconfig >/dev/null 2>&1; then
        candidate="$(ldconfig -p 2>/dev/null | awk -v library_name="$library_name" '$1 == library_name { print $NF; exit }')"
        if [ -n "$candidate" ] && [ -f "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    fi

    for candidate in \
        "/usr/lib/$library_name" \
        "/usr/lib64/$library_name" \
        "/usr/lib/x86_64-linux-gnu/$library_name" \
        "/usr/local/lib/$library_name" \
        "/run/host/usr/lib/$library_name" \
        "/run/host/usr/lib64/$library_name"; do
        if [ -f "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

copy_system_glew_dependency() {
    local binary_path="$1"
    local target_dir="$2"
    local required_library=""
    local source_path=""
    local target_path=""

    if [ ! -f "$binary_path" ] || ! command -v readelf >/dev/null 2>&1; then
        return
    fi

    required_library="$(readelf -d "$binary_path" 2>/dev/null | awk -F'[][]' '/NEEDED/ && $2 ~ /^libGLEW\.so\./ { print $2; exit }')"
    if [ -z "$required_library" ] || [ -f "$target_dir/$required_library" ]; then
        return
    fi

    if ! source_path="$(find_shared_library "$required_library")"; then
        return
    fi

    target_path="$target_dir/$required_library"
    cp "$source_path" "$target_path"
    chmod 0755 "$target_path"
}

trap cleanup_temp_runtime EXIT

if [ "${CATHOOK_TEXTMODE:-0}" = "1" ] || [ "${TEXTMODE:-0}" = "1" ]; then
    CATHOOK_BINARY=libcathooktextmode.so
fi

LIB_PATH="$CATHOOK_BIN_DIR/$CATHOOK_BINARY"
if [ ! -f "$LIB_PATH" ] && [ -f "$SCRIPT_DIR/bin/$CATHOOK_BINARY" ]; then
    LIB_PATH="$SCRIPT_DIR/bin/$CATHOOK_BINARY"
fi

if [ ! -f "$LIB_PATH" ]; then
    echo "Missing $CATHOOK_BINARY. Run ./build.sh first."
    exit 1
fi

if pgrep -u "$USER" -x tf_linux64 >/dev/null 2>&1 || pgrep -u "$USER" -x hl2_linux >/dev/null 2>&1; then
    echo "TF2 is already running"
    exit 1
fi

if ! pgrep -u "$USER" -x steam >/dev/null 2>&1; then
    echo "Steam is not running; starting it"
    steam >/dev/null 2>&1 &
    sleep 30
fi

TF2_PATH=${TF2_PATH:-"$HOME/.steam/steam/steamapps/common/Team Fortress 2"}
TF2_PATH=$(realpath "$TF2_PATH")

if [ -x "$TF2_PATH/tf_linux64" ]; then
    GAME_BIN="$TF2_PATH/tf_linux64"
elif [ -x "$TF2_PATH/hl2_linux" ]; then
    GAME_BIN="$TF2_PATH/hl2_linux"
else
    echo "Could not find a TF2 Linux executable in $TF2_PATH"
    exit 1
fi

TMP_RUNTIME_DIR=$(mktemp -d /tmp/.glXXXXXX)
TMP_LIB="$TMP_RUNTIME_DIR/$CATHOOK_BINARY"
cp "$LIB_PATH" "$TMP_LIB"
chmod 0755 "$TMP_LIB"
copy_bundled_runtime_dependencies "$(dirname -- "$LIB_PATH")" "$TMP_RUNTIME_DIR"
if [ "$(dirname -- "$LIB_PATH")" != "$CATHOOK_BIN_DIR" ]; then
    copy_bundled_runtime_dependencies "$CATHOOK_BIN_DIR" "$TMP_RUNTIME_DIR"
fi
copy_system_glew_dependency "$LIB_PATH" "$TMP_RUNTIME_DIR"

echo "Preloading $CATHOOK_BINARY as $TMP_LIB"
(
    cd "$TF2_PATH"
    CATHOOK_AUTO_ATTACH=1 LD_PRELOAD="$TMP_LIB" LD_LIBRARY_PATH="$TMP_RUNTIME_DIR:$CATHOOK_BIN_DIR:$TF2_PATH/bin:${LD_LIBRARY_PATH:-}" "$GAME_BIN" -game tf >/dev/null 2>&1 &
)

sleep 10
cleanup_temp_runtime
echo "Game preloading"
